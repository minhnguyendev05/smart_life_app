rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function roomMemberPath(roomId) {
      return /databases/$(database)/documents/chat_rooms/$(roomId)/members/$(request.auth.uid);
    }

    function roomMemberDoc(roomId) {
      return get(roomMemberPath(roomId));
    }

    function isRoomMember(roomId) {
      return signedIn() && exists(roomMemberPath(roomId));
    }

    function isRoomAdmin(roomId) {
      return isRoomMember(roomId)
        && (roomMemberDoc(roomId).data.role == 'owner' || roomMemberDoc(roomId).data.role == 'admin');
    }

    function validRole(role) {
      return role in ['owner', 'admin', 'member'];
    }

    // ---------- User scoped notes ----------
    match /users/{uid}/notes/{noteId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(uid);
    }

    // ---------- User scoped finance categories ----------
    match /users/{uid}/finance_categories/{categoryId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(uid);
    }

    // ---------- User scoped finance transactions ----------
    match /users/{uid}/finance_transactions/{txId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(uid);
    }

    // ---------- User scoped finance recurring ----------
    match /users/{uid}/finance_recurring/{recurringId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(uid);
    }

    // ---------- User scoped finance settings ----------
    match /users/{uid}/finance_settings/{docId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(uid);
    }

    // ---------- User scoped study tasks ----------
    match /users/{uid}/study_tasks/{taskId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(uid);
    }

    // ---------- User scoped sync outbox ----------
    match /users/{uid}/sync_outbox/{actionId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.actionId == actionId
        && request.resource.data.entity is string
        && request.resource.data.entityId is string;
      allow delete: if isOwner(uid)
        && resource.data.uid is string
        && resource.data.uid == request.auth.uid;
    }

    // ---------- User scoped sync conflicts ----------
    match /users/{uid}/sync_conflicts/{conflictId} {
      allow read, create, update, delete: if isOwner(uid);
    }

    // ---------- User scoped sync entity audit ----------
    match /users/{uid}/sync_entities/{docId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.entity is string
        && request.resource.data.entityId is string;
      allow delete: if isOwner(uid)
        && resource.data.uid is string
        && resource.data.uid == request.auth.uid;
    }

    // ---------- Global finance system categories ----------
    match /finance_system_categories/{categoryId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.id is string
        && request.resource.data.id == categoryId
        && request.resource.data.isSystem == true
        && request.resource.data.type is string
        && request.resource.data.name is string
        && request.resource.data.group is string
        && request.resource.data.iconCodePoint is number
        && request.resource.data.colorValue is number;
      allow delete: if false;
    }

    // ---------- App users (global profile directory) ----------
    match /app_users/{uid} {
      allow read: if signedIn();
      allow create: if isOwner(uid) && request.resource.data.id == uid;
      allow update: if isOwner(uid) && request.resource.data.id == uid;
      allow delete: if false;
    }

    // ---------- Chat rooms ----------
    match /chat_rooms/{roomId} {
      allow read: if isRoomMember(roomId);

      // Room creator must be the authenticated user.
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;

      // Admins can manage room metadata.
      // Members may only update rolling last-message fields.
      allow update: if isRoomAdmin(roomId)
        || (
          isRoomMember(roomId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'memberCount'])
        );

      allow delete: if isRoomAdmin(roomId);

      match /members/{userId} {
        allow read: if isRoomMember(roomId);

        // Self-join is allowed as member; creator may self-create as owner.
        allow create: if signedIn()
          && (
            (
              request.auth.uid == userId
              && validRole(request.resource.data.role)
              && request.resource.data.userId == userId
            )
            || isRoomAdmin(roomId)
          );

        allow update, delete: if isRoomAdmin(roomId);
      }

      match /messages/{messageId} {
        allow read: if isRoomMember(roomId);

        allow create: if isRoomMember(roomId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.sender is string
          && request.resource.data.text is string;

        // Reactions and seen-state updates from members.
        allow update: if isRoomMember(roomId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['reactions', 'seen']);

        allow delete: if false;
      }

      match /meta/{docId} {
        allow read, write: if isRoomMember(roomId);
      }
    }

  }
}
